{
  "name": "opencode-wechat-plugin",
  "version": "0.1.0",
  "description": "OpenCode plugin that bridges WeChat (iLink bot) to your OpenCode session: inbound DMs become prompts, agent replies are pushed to WeChat, and the agent gets a wechat_notify tool to proactively notify you.",
  "type": "module",
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js",
    "./tui": "./dist/src/tui.js"
  },
  "bin": {
    "opencode-wechat": "./dist/src/bridge/cli.js"
  },
  "files": [
    "dist/src/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "prepublishOnly": "npm run clean && npm run build && npm test -- --run",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "bind": "node dist/src/bridge/cli.js bind",
    "poll": "node dist/src/bridge/cli.js poll"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.14.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "better-sqlite3": "^11.5.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "wechat",
    "weixin",
    "ilink",
    "agent-bridge"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.14.31",
    "zod": "^4.4.2"
  }
}
